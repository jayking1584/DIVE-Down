    Label{Size=UDim2.new(1,-80,1,0), Position=UDim2.new(0,38,0,0), Text=title,
          TextColor3=T.TXT_WHITE, Font=Enum.Font.GothamBold, TextSize=13,
          TextXAlignment=Enum.TextXAlignment.Left, ZIndex=3, Parent=hdr}
    local x = Instance.new("TextButton")
    x.Size = UDim2.new(0,28,0,28); x.Position = UDim2.new(1,-34,0,6)
    x.BackgroundColor3 = Color3.fromRGB(60,20,30); x.TextColor3 = Color3.fromRGB(255,100,120)
