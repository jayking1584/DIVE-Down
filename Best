local isAutoRunning=false

local function SetAutoUI(running)
    isAutoRunning=running
    if running then
        startMainLbl.Text="STOP AUTO TARGET"
        startIcLbl.Text="■"
        Tween(startBtn,{BackgroundColor3=Color3.fromRGB(80,20,20)})
        Tween(startIc, {BackgroundColor3=Color3.fromRGB(120,24,24)})
        startMainLbl.TextColor3=T.RED
        startIcLbl.TextColor3=T.RED
        local st=startBtn:FindFirstChildOfClass("UIStroke")
        if st then st.Color=T.RED end
    else
        startMainLbl.Text="START AUTO TARGET"
        startIcLbl.Text="▶"
        Tween(startBtn,{BackgroundColor3=Color3.fromRGB(14,90,80)})
        Tween(startIc, {BackgroundColor3=Color3.fromRGB(16,120,90)})
        startMainLbl.TextColor3=T.GREEN
        startIcLbl.TextColor3=T.GREEN
        local st=startBtn:FindFirstChildOfClass("UIStroke")
        if st then st.Color=T.GREEN end
        atStatusLbl.Text="Auto Target is OFF"
        atStatusLbl.TextColor3=T.TXT_DIM
        Tween(atStatusFrame,{BackgroundColor3=T.BG_CARD})
    end
end

startBtn.MouseButton1Click:Connect(function()
    if isAutoRunning then
        AutoTarget:Stop()
        SetAutoUI(false)
    else
        -- build target keys from toggles
        local keys={}
        local count=0
        for key, t in pairs(rarityToggles) do
            if t.enabled then keys[key]=true; count=count+1 end
        end
        if count==0 then
            startSubLbl.Text="Enable at least one rarity!"
            startSubLbl.TextColor3=T.RED
            task.delay(2,function()
                startSubLbl.Text="Select rarities above first"
                startSubLbl.TextColor3=T.TXT_DIM
            end)
            return
        end
        SetAutoUI(true)
        AutoTarget:Start(keys, function(msg, col)
            atStatusLbl.Text=msg
            atStatusLbl.TextColor3=col or T.TXT_DIM
            if col==T.CYAN then
                Tween(atStatusFrame,{BackgroundColor3=Color3.fromRGB(10,40,60)})
            elseif col and col~=T.TXT_DIM then
                Tween(atStatusFrame,{BackgroundColor3=Color3.fromRGB(20,36,56)})
            end
        end)
        startSubLbl.Text="Running — targeting "..count.." rarity tier(s)"
        startSubLbl.TextColor3=T.TXT_DIM
    end
end)

