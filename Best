-- RARITY
local RARITY_RANK = {
    common=1, uncommon=2, rare=3, epic=4,
    legendary=5, mythical=6, exotic=7, divine=8, secret=9,
}
local LOW_RARITIES = { common=true, uncommon=true, rare=true }

local function RarityKey(raw)
    if not raw or raw == "" then return nil end
    local tl = Trim(raw):lower()
    if RARITY_RANK[tl] then return tl end
    for k in pairs(RARITY_RANK) do
        if tl:find(k, 1, true) then return k end
    end
    return nil
end
local function RarityColor(key)
    if key == "secret"    then return T.SECRET   end
    if key == "divine"    then return T.DIVINE   end
    if key == "mythical"  then return T.MYTHICAL end
    if key == "legendary" then return T.LEGENDARY end
    if key == "exotic"    then return T.EXOTIC   end
    if key == "epic"      then return T.EPIC     end
    return T.TXT_DIM
end
local function ToTitle(s)
    if not s or s == "" then return "" end
    return s:sub(1,1):upper() .. s:sub(2):lower()
end

-- RECURSIVE BILLBOARD SCANNER
local function ReadBillboard(bbg)
    local rarityRaw  = nil
    local mutationRaw = "None"
    for _, lbl in ipairs(bbg:GetDescendants()) do
        if lbl:IsA("TextLabel") then
            local nl = lbl.Name:lower()
            local tv = Trim(lbl.Text)
            local tl = tv:lower()
            if not rarityRaw then
                if nl == "rarity" or nl:find("rarity") then
                    if tv ~= "" then rarityRaw = tv end
                elseif RARITY_RANK[tl] then
                    rarityRaw = tv
                else
                    for k in pairs(RARITY_RANK) do
                        if tl:find(k, 1, true) then rarityRaw = tv; break end
                    end
                end
            end
            if nl == "mutations" or nl == "mutation" then
                if tv ~= "" and tv ~= "None" then mutationRaw = tv end
            end
        end
    end
    return rarityRaw, mutationRaw
end

local function FindProximityPrompt(model)
    for _, d in ipairs(model:GetDescendants()) do
        if d:IsA("ProximityPrompt") then return d end
    end
    return nil
end
local function GetModelPart(model)
    return model:FindFirstChild("RootPart")
        or model.PrimaryPart
        or model:FindFirstChildWhichIsA("BasePart")
end

-- Single pass scan — accumulates into provided tables (allows multi-zone dedup)
local function ScanCurrentArea(filterFn, seenModels, resultTable, rarityCount)
    seenModels  = seenModels  or {}
    resultTable = resultTable or {}
    rarityCount = rarityCount or {}
    for _, desc in ipairs(workspace:GetDescendants()) do
        if not desc:IsA("BillboardGui") then continue end
        local model = desc.Parent
        while model and not model:IsA("Model") do
            model = model.Parent
        end
        if not model or model == workspace then continue end
        if seenModels[model] then continue end
        seenModels[model] = true
        local rarityRaw, mutationRaw = ReadBillboard(desc)
        if not rarityRaw then continue end
        local key = RarityKey(rarityRaw)
        if not key then continue end
        rarityCount[key] = (rarityCount[key] or 0) + 1
        if filterFn and not filterFn(key) then continue end
        local part = GetModelPart(model)
        if not part then continue end
        table.insert(resultTable, {
            name      = model.Name,
            rarityKey = key,
            rarityRaw = rarityRaw,
            mutation  = mutationRaw,
            rank      = RARITY_RANK[key] or 0,
            model     = model,
            part      = part,
            prompt    = FindProximityPrompt(model),
            position  = part.Position,
        })
    end
    return resultTable, rarityCount
end

-- ZONE SWEEP — teleport to each FishZone, wait for fish to stream in, scan, repeat
local zoneSweepRunning = false

local function GetZonePositions()
    local zones = {}
    local folder = workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("FishZones")
    if not folder then return zones end
    for _, item in ipairs(folder:GetChildren()) do
        local pos = nil
        if item:IsA("BasePart") then
            pos = item.Position
        elseif item:IsA("Model") and item.PrimaryPart then
            pos = item.PrimaryPart.Position
        end
        if pos then
            table.insert(zones, { name = item.Name, position = pos })
        end
    end
    return zones
end

local function SweepAllZones(filterFn, progressFn, doneFn)
    if zoneSweepRunning then return end
    zoneSweepRunning = true
    local zones       = GetZonePositions()
    local allFish     = {}
    local allRarity   = {}
    local seenModels  = {}
    if #zones == 0 then
        progressFn("No zones found — scanning current area")
        task.wait(0.5)
        ScanCurrentArea(filterFn, seenModels, allFish, allRarity)
        table.sort(allFish, function(a, b) return a.rank > b.rank end)
        zoneSweepRunning = false
        doneFn(allFish, allRarity)
        return
    end
    local originPos = GetHRP() and GetHRP().Position or Vector3.new(0, 0, 0)
    task.spawn(function()
        for i, zone in ipairs(zones) do
            progressFn(string.format("Sweeping %d/%d — %s", i, #zones, zone.name))
            local hrp = GetHRP()
            if hrp then
                hrp.CFrame = CFrame.new(zone.position + Vector3.new(0, 6, 0))
            end
            -- wait for streaming/physics to settle and BillboardGuis to appear
            task.wait(1.4)
            ScanCurrentArea(filterFn, seenModels, allFish, allRarity)
        end
        progressFn("Returning to start…")
        local hrp = GetHRP()
        if hrp then
            hrp.CFrame = CFrame.new(originPos + Vector3.new(0, 4, 0))
        end
        task.wait(0.3)
        table.sort(allFish, function(a, b) return a.rank > b.rank end)
        zoneSweepRunning = false
        doneFn(allFish, allRarity)
    end)
end

-- AUTO TARGET ENGINE
local FOLLOW_DIST  = 8
local PROMPT_RANGE = 12
local AutoTarget = {
    running=false, connection=nil, currentFish=nil,
    targetKeys={}, statusFn=nil,
    scanInterval=3, lastScan=0, catchDelay=0.4,
}
local function FirePrompt(prompt)
    pcall(function() fireproximityprompt(prompt) end)
    pcall(function()
        prompt:InputHoldBegin()
        task.delay(0.1, function() pcall(function() prompt:InputHoldEnd() end) end)
    end)
end
function AutoTarget:FindBestFish()
    local hrp = GetHRP()
    local fish = ScanCurrentArea(function(k) return self.targetKeys[k] end)
    if #fish == 0 then return nil end
    if hrp then
        table.sort(fish, function(a, b)
            local pa = GetModelPart(a.model)
            local pb = GetModelPart(b.model)
            if not pa then return false end
            if not pb then return true end
            local da = (hrp.Position - pa.Position).Magnitude
            local db = (hrp.Position - pb.Position).Magnitude
            return (da - a.rank*10) < (db - b.rank*10)
        end)
    end
    for _, f in ipairs(fish) do
        if f.prompt and f.prompt.Parent then
            f.prompt = FindProximityPrompt(f.model) or f.prompt
            return f
        end
    end
    return fish[1]
end
function AutoTarget:Start(targetKeys, statusFn)
    if self.running then self:Stop() end
    self.running     = true
    self.targetKeys  = targetKeys or {}
    self.statusFn    = statusFn or function() end
    self.lastScan    = 0
    self.currentFish = nil
    local lastFire   = 0
    self.connection  = RunService.Heartbeat:Connect(function()
        if not self.running then return end
        local now = tick()
        local hrp = GetHRP()
        if not hrp then return end
        local fishGone = self.currentFish and (
            not self.currentFish.model.Parent or
            not GetModelPart(self.currentFish.model)
        )
        if fishGone or (now - self.lastScan) >= self.scanInterval then
            self.lastScan    = now
            self.currentFish = self:FindBestFish()
            if self.currentFish then
                self.statusFn(
                    "Targeting: " .. self.currentFish.name ..
                    " [" .. ToTitle(self.currentFish.rarityKey) .. "]",
                    RarityColor(self.currentFish.rarityKey)
                )
            else
                self.statusFn("Scanning for fish…", T.TXT_DIM)
            end
        end
        if not self.currentFish then return end
        local fPart = GetModelPart(self.currentFish.model)
        if not fPart then self.currentFish = nil; return end
        local dist = (hrp.Position - fPart.Position).Magnitude
        if dist > FOLLOW_DIST then
            local hum = GetHumanoid()
            if hum then hum:MoveTo(fPart.Position) end
        end
        if dist <= PROMPT_RANGE and (now - lastFire) >= self.catchDelay then
            lastFire = now
            local prompt = self.currentFish.prompt or FindProximityPrompt(self.currentFish.model)
            if prompt and prompt.Parent then
                FirePrompt(prompt)
                self.statusFn("Catching: " .. self.currentFish.name, T.CYAN)
            else
                self.statusFn("Waiting: " .. self.currentFish.name .. " (no prompt)", T.GOLD)
            end
        end
    end)
end
function AutoTarget:Stop()
    self.running = false
    if self.connection then
        self.connection:Disconnect()
        self.connection = nil
    end
    self.currentFish = nil
    local hum = GetHumanoid()
    local hrp = GetHRP()
    if hum and hrp then pcall(function() hum:MoveTo(hrp.Position) end) end
end

-- AIR TIMER
local AirTimer = {
    running=false, totalSeconds=120, remaining=120,
    connection=nil, onTick=nil, onExpire=nil, lastTick=0,
}
function AirTimer:SetTime(mins, secs)
    self.totalSeconds = math.max(1, mins*60 + secs)
    self.remaining    = self.totalSeconds
    if self.onTick then self.onTick(self.remaining, self.totalSeconds) end
end
function AirTimer:Start()
    if self.running then return end
    self.running   = true
    self.remaining = self.totalSeconds
    self.lastTick  = tick()
    self.connection = RunService.Heartbeat:Connect(function()
        if not self.running then return end
        local now = tick()
        local dt  = now - self.lastTick
        self.lastTick  = now
        self.remaining = self.remaining - dt
        if self.onTick then self.onTick(self.remaining, self.totalSeconds) end
        if self.remaining <= 0 then
            self:_stop()
            if self.onExpire then self.onExpire() end
        end
    end)
end
function AirTimer:_stop()
    self.running = false
    if self.connection then self.connection:Disconnect(); self.connection = nil end
end
function AirTimer:Stop()
    self:_stop()
    self.remaining = self.totalSeconds
    if self.onTick then self.onTick(self.remaining, self.totalSeconds) end
end

-- SERVER HOP
local hopRunning = false
local PLACE_ID   = game.PlaceId
local function GetRandomServer()
    local url = string.format(
        "https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100", PLACE_ID)
    local ok, result = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
    if not ok or not result or not result.data then return nil end
    local servers = {}
    for _, s in ipairs(result.data) do
        if s.id ~= game.JobId and s.playing < s.maxPlayers then
            table.insert(servers, s)
        end
    end
    if #servers == 0 then return nil end
    return servers[math.random(1, #servers)]
end
local function DoServerHop(statusFn)
    if hopRunning then return end
    hopRunning = true
    statusFn("Fetching servers…", T.GOLD)
    task.spawn(function()
        local server = GetRandomServer()
        if not server then
            statusFn("No servers found!", T.RED)
            task.wait(2); statusFn("Jump to a new server", T.TXT_DIM)
            hopRunning = false; return
        end
        statusFn("Hopping…", T.CYAN); task.wait(0.5)
        local ok, err = pcall(function()
            TeleportService:TeleportToPlaceInstance(PLACE_ID, server.id, LocalPlayer)
        end)
        if not ok then
            statusFn("Failed: " .. tostring(err):sub(1,24), T.RED)
            task.wait(2); statusFn("Jump to a new server", T.TXT_DIM)
            hopRunning = false
        end
    end)
end

