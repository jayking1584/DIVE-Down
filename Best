-- ══════════════════════════════════════════════════════════════════════════
--  RARITY SYSTEM
-- ══════════════════════════════════════════════════════════════════════════
local RARITY_RANK = {
    common=1, uncommon=2, rare=3, epic=4,
    legendary=5, mythical=6, exotic=7, divine=8, secret=9,
}
local LOW_RARITIES = { common=true, uncommon=true, rare=true }

local function RarityKey(raw)
    if not raw or raw=="" then return nil end
    local tl=Trim(raw):lower()
    if RARITY_RANK[tl] then return tl end
    for k in pairs(RARITY_RANK) do
        if tl:find(k,1,true) then return k end
    end
    return nil
end

local function RarityColor(key)
    if key=="secret"    then return T.SECRET   end
    if key=="divine"    then return T.DIVINE   end
    if key=="mythical"  then return T.MYTHICAL end
    if key=="legendary" then return T.LEGENDARY end
    if key=="exotic"    then return T.EXOTIC   end
    if key=="epic"      then return T.EPIC     end
    return T.TXT_DIM
end

local function ToTitle(s)
    if not s or s=="" then return "" end
    return s:sub(1,1):upper()..s:sub(2):lower()
end

-- ══════════════════════════════════════════════════════════════════════════
--  RECURSIVE BILLBOARD SCANNER
--  Walks ALL descendants of workspace looking for BillboardGuis.
--  For each billboard found, climbs up to the owning Model.
--  Reads rarity/mutation from every TextLabel inside the billboard.
--  Returns de-duplicated list of fish data with live model references.
-- ══════════════════════════════════════════════════════════════════════════
local function ReadBillboard(bbg)
    local rarityRaw, mutationRaw = nil, "None"
    for _, lbl in ipairs(bbg:GetDescendants()) do
        if lbl:IsA("TextLabel") then
            local nl = lbl.Name:lower()
            local tv = Trim(lbl.Text)
            local tl = tv:lower()
            -- rarity: name match first (strongest), then text match
            if not rarityRaw then
                if nl=="rarity" or nl:find("rarity") then
                    if tv~="" then rarityRaw=tv end
                elseif RARITY_RANK[tl] then
                    rarityRaw=tv
                else
                    for k in pairs(RARITY_RANK) do
                        if tl:find(k,1,true) then rarityRaw=tv; break end
                    end
                end
            end
            -- mutation: name match
            if nl=="mutations" or nl=="mutation" then
                if tv~="" and tv~="None" then mutationRaw=tv end
            end
        end
    end
    return rarityRaw, mutationRaw
end

-- Find the ProximityPrompt inside a fish model (any depth)
local function FindProximityPrompt(model)
    for _, d in ipairs(model:GetDescendants()) do
        if d:IsA("ProximityPrompt") then return d end
    end
    return nil
end

-- Get the best BasePart position for a model (for teleport / follow)
local function GetModelPart(model)
    return model:FindFirstChild("RootPart")
        or model.PrimaryPart
        or model:FindFirstChildWhichIsA("BasePart")
end

local function ScanWorkspaceForFish(filterFn)
    local seen   = {}
    local result = {}
    local rarityCount = {}

    for _, desc in ipairs(workspace:GetDescendants()) do
        if not desc:IsA("BillboardGui") then continue end

        -- climb to owning Model
        local model = desc.Parent
        while model and not model:IsA("Model") do
            model = model.Parent
        end
        if not model or model==workspace then continue end
        if seen[model] then continue end
        seen[model] = true

        local rarityRaw, mutationRaw = ReadBillboard(desc)
        if not rarityRaw then continue end

        local key = RarityKey(rarityRaw)
        if not key then continue end

        rarityCount[key] = (rarityCount[key] or 0) + 1

        -- apply filter
        if filterFn and not filterFn(key) then continue end

        local part = GetModelPart(model)
        if not part then continue end

        table.insert(result, {
            name       = model.Name,
            rarityKey  = key,
            rarityRaw  = rarityRaw,
            mutation   = mutationRaw,
            rank       = RARITY_RANK[key] or 0,
            model      = model,
            part       = part,
            prompt     = FindProximityPrompt(model),
        })
    end

    table.sort(result, function(a,b) return a.rank > b.rank end)
    return result, rarityCount
end

-- ══════════════════════════════════════════════════════════════════════════
--  AUTO TARGET ENGINE
--  Continuously follows the target fish model and fires its ProximityPrompt
--  whenever within range. Handles fish that move around.
-- ══════════════════════════════════════════════════════════════════════════
local AutoTarget = {}
AutoTarget.running      = false
AutoTarget.connection   = nil   -- RunService connection
AutoTarget.currentFish  = nil   -- current fish data table
AutoTarget.targetKeys   = {}    -- set of rarity keys to auto-catch
AutoTarget.statusFn     = nil   -- callback(text, color) for UI updates
AutoTarget.scanInterval = 3     -- re-scan for new fish every N seconds
AutoTarget.lastScan     = 0
AutoTarget.catchDelay   = 0.4   -- seconds between prompt fires

local FOLLOW_DIST  = 8   -- how close to get before firing prompt (studs)
local PROMPT_RANGE = 12  -- fire prompt if within this range

local function FirePrompt(prompt)
    -- FireProximityPrompt triggers the server-side catch logic
    local ok = pcall(function()
        fireclickdetector and fireclickdetector(prompt)
    end)
    if not ok then
        pcall(function()
            prompt:InputHoldBegin()
            task.delay(0.1, function() pcall(function() prompt:InputHoldEnd() end) end)
        end)
    end
    -- Primary method: fire the proximity prompt directly
    pcall(function()
        fireproximityprompt(prompt)
    end)
end

local function GetHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function GetHumanoid()
    local char = LocalPlayer.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function MoveToward(part)
    local hum = GetHumanoid()
    if hum and part and part.Parent then
        hum:MoveTo(part.Position)
    end
end

function AutoTarget:FindBestFish()
    local hrp = GetHRP()
    local filterFn = function(key) return self.targetKeys[key] end
    local fish, _ = ScanWorkspaceForFish(filterFn)
    if #fish == 0 then return nil end

    -- pick closest alive fish that still has a prompt
    if hrp then
        table.sort(fish, function(a, b)
            local pa = GetModelPart(a.model)
            local pb = GetModelPart(b.model)
            if not pa then return false end
            if not pb then return true end
            local da = (hrp.Position - pa.Position).Magnitude
            local db = (hrp.Position - pb.Position).Magnitude
            -- weight: closer + higher rarity wins
            local scoreA = da - (a.rank * 10)
            local scoreB = db - (b.rank * 10)
            return scoreA < scoreB
        end)
    end

    -- return first fish that has a live prompt
    for _, f in ipairs(fish) do
        if f.prompt and f.prompt.Parent then
            -- re-find prompt in case model updated
            f.prompt = FindProximityPrompt(f.model) or f.prompt
            return f
        end
    end
    return fish[1]  -- fallback even without prompt
end

function AutoTarget:Start(targetKeys, statusFn)
    if self.running then self:Stop() end
    self.running     = true
    self.targetKeys  = targetKeys or {}
    self.statusFn    = statusFn or function() end
    self.lastScan    = 0
    self.currentFish = nil

    local lastFire = 0

    self.connection = RunService.Heartbeat:Connect(function(dt)
        if not self.running then return end

        local now   = tick()
        local hrp   = GetHRP()
        if not hrp then return end

        -- re-scan periodically or if current fish is gone
        local fishGone = self.currentFish and (
            not self.currentFish.model.Parent or
            not GetModelPart(self.currentFish.model)
        )

        if fishGone or (now - self.lastScan) >= self.scanInterval then
            self.lastScan    = now
            self.currentFish = self:FindBestFish()
            if self.currentFish then
                self.statusFn(
                    "Targeting: "..self.currentFish.name
                    .." ["..ToTitle(self.currentFish.rarityKey).."]",
                    RarityColor(self.currentFish.rarityKey)
                )
            else
                self.statusFn("Scanning for fish…", T.TXT_DIM)
            end
        end

        if not self.currentFish then return end

        local fish  = self.currentFish
        local fPart = GetModelPart(fish.model)
        if not fPart then
            self.currentFish = nil
            return
        end

        local dist = (hrp.Position - fPart.Position).Magnitude

        -- always walk toward the fish so we stay in range
        if dist > FOLLOW_DIST then
            MoveToward(fPart)
        end

        -- fire prompt when close enough and cooldown elapsed
        if dist <= PROMPT_RANGE and (now - lastFire) >= self.catchDelay then
            lastFire = now
            local prompt = fish.prompt or FindProximityPrompt(fish.model)
            if prompt and prompt.Parent then
                FirePrompt(prompt)
                self.statusFn(
                    "⚡ Catching: "..fish.name,
                    T.CYAN
                )
            else
                -- no prompt found — just stay close, game may add it
                self.statusFn(
                    "Waiting: "..fish.name.." (no prompt yet)",
                    T.GOLD
                )
            end
        end
    end)
end

function AutoTarget:Stop()
    self.running = false
    if self.connection then
        self.connection:Disconnect()
        self.connection = nil
    end
    self.currentFish = nil
    -- stop humanoid movement
    local hum = GetHumanoid()
    if hum then pcall(function() hum:MoveTo(GetHRP().Position) end) end
end

