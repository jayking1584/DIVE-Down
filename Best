local function MakeScroll(parent, offsetY)
    local s=Instance.new("ScrollingFrame")
    s.Size=UDim2.new(1,-14,1,-(offsetY+8))
    s.Position=UDim2.new(0,7,0,offsetY+4)
    s.BackgroundTransparency=1; s.ScrollBarThickness=3
    s.ScrollBarImageColor3=T.CYAN; s.ScrollBarImageTransparency=0.3
    s.CanvasSize=UDim2.new(0,0,0,0); s.BorderSizePixel=0; s.Parent=parent
    local l=Instance.new("UIListLayout"); l.Padding=UDim.new(0,6)
    l.HorizontalAlignment=Enum.HorizontalAlignment.Center
    l.SortOrder=Enum.SortOrder.LayoutOrder; l.Parent=s
    l:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        s.CanvasSize=UDim2.new(0,0,0,l.AbsoluteContentSize.Y+10)
    end)
    return s
end

