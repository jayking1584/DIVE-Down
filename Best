local function MakePanel(title, icon, sizeX, sizeY, posX, posY)
    local frame = Instance.new("Frame")
    frame.Size             = UDim2.new(0, sizeX, 0, sizeY)
    frame.Position         = UDim2.new(0, posX, 0, posY)
    frame.BackgroundColor3 = T.BG_PANEL
    frame.BorderSizePixel  = 0
    frame.Active           = true
    frame.Draggable        = true
    frame.ClipsDescendants = true
    frame.Parent           = ScreenGui
    Corner(frame, 12); Stroke(frame, T.CYAN, 1)
    Gradient(frame, Color3.fromRGB(12,26,48), Color3.fromRGB(7,15,28), 160)
    local hdr = Instance.new("Frame")
    hdr.Size = UDim2.new(1,0,0,40); hdr.BackgroundColor3 = T.BG_HEADER
    hdr.BorderSizePixel = 0; hdr.ZIndex = 2; hdr.Parent = frame; Corner(hdr, 12)
    local accent = Instance.new("Frame")
