local function BuildFishCards(showHighOnly)
    for _, c in ipairs(fishScroll:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end
    statusLbl.Text="Scanning workspace…"; debugLbl.Text=""

    local filterFn = showHighOnly and function(k) return not LOW_RARITIES[k] end or nil
    local data, rarityCount = ScanWorkspaceForFish(filterFn)

    local parts={}
    for k,n in pairs(rarityCount) do table.insert(parts, ToTitle(k)..":"..n) end
    table.sort(parts); debugLbl.Text=#parts>0 and table.concat(parts," ") or "None found"

    if #data==0 then
        statusLbl.Text="Nothing found"
        Label{Size=UDim2.new(1,-8,0,80),
              Text=showHighOnly
                  and "No Epic+ fish.\nAll rarities: "..debugLbl.Text
                  or  "No BillboardGui fish found.",
              TextColor3=T.TXT_DIM,Font=Enum.Font.Gotham,
              TextSize=11,TextWrapped=true,Parent=fishScroll}
        return
    end

    statusLbl.Text=(showHighOnly and "Epic+: " or "All: ")..#data.." fish"

    for i, fish in ipairs(data) do
        local rc=RarityColor(fish.rarityKey)
        local card=Instance.new("Frame"); card.Size=UDim2.new(1,-4,0,56)
        card.BackgroundColor3=T.BG_CARD; card.BorderSizePixel=0
        card.LayoutOrder=i; card.Parent=fishScroll; Corner(card,10)

        local stripe=Instance.new("Frame"); stripe.Size=UDim2.new(0,3,1,-12)
        stripe.Position=UDim2.new(0,0,0,6); stripe.BackgroundColor3=rc
        stripe.BorderSizePixel=0; stripe.Parent=card; Corner(stripe,2)

        Label{Size=UDim2.new(0.55,0,0,22),Position=UDim2.new(0,12,0,7),
              Text=fish.name,TextColor3=T.TXT_WHITE,Font=Enum.Font.GothamBold,
              TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,
              TextTruncate=Enum.TextTruncate.AtEnd,Parent=card,ZIndex=2}

        local badge=Instance.new("Frame"); badge.Size=UDim2.new(0,74,0,18)
        badge.Position=UDim2.new(0,12,0,31); badge.BackgroundColor3=rc
        badge.BackgroundTransparency=0.75; badge.BorderSizePixel=0
        badge.Parent=card; badge.ZIndex=2; Corner(badge,4)
        Label{Size=UDim2.new(1,0,1,0),Text=fish.rarityRaw:upper(),
              TextColor3=rc,Font=Enum.Font.GothamBold,TextSize=9,
              Parent=badge,ZIndex=3}

        if fish.mutation~="None" and fish.mutation~="" then
            Label{Size=UDim2.new(0,100,0,18),Position=UDim2.new(0,90,0,31),
                  Text="✦ "..fish.mutation,TextColor3=T.GOLD,
                  Font=Enum.Font.Gotham,TextSize=10,
                  TextXAlignment=Enum.TextXAlignment.Left,
                  Parent=card,ZIndex=2}
        end

        -- GO teleport button
        local go=Instance.new("TextButton"); go.Size=UDim2.new(0,52,0,32)
        go.Position=UDim2.new(1,-114,0.5,-16)
        go.BackgroundColor3=Color3.fromRGB(16,60,90); go.TextColor3=T.CYAN
        go.Text="▶ GO"; go.Font=Enum.Font.GothamBold; go.TextSize=11
        go.BorderSizePixel=0; go.Parent=card; go.ZIndex=3
        Corner(go,7); Stroke(go,T.CYAN,1)

        -- TARGET button (single fish auto-catch)
        local tgt=Instance.new("TextButton"); tgt.Size=UDim2.new(0,52,0,32)
        tgt.Position=UDim2.new(1,-58,0.5,-16)
        tgt.BackgroundColor3=Color3.fromRGB(40,16,70); tgt.TextColor3=T.MYTHICAL
        tgt.Text="🎯"; tgt.Font=Enum.Font.GothamBold; tgt.TextSize=14
        tgt.BorderSizePixel=0; tgt.Parent=card; tgt.ZIndex=3
        Corner(tgt,7); Stroke(tgt,T.MYTHICAL,1)

        local modelRef=fish.model; local partRef=fish.part

        go.MouseEnter:Connect(function() Tween(go,{BackgroundColor3=Color3.fromRGB(20,100,130)}) end)
        go.MouseLeave:Connect(function() Tween(go,{BackgroundColor3=Color3.fromRGB(16,60,90)}) end)
        go.MouseButton1Click:Connect(function()
            local hrp=LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            local pos
            if partRef and partRef.Parent then pos=partRef.Position
            elseif modelRef and modelRef.Parent then
                local p=modelRef.PrimaryPart or modelRef:FindFirstChildWhichIsA("BasePart")
                if p then pos=p.Position end
            end
            if pos then hrp.CFrame=CFrame.new(pos+Vector3.new(0,5,0)) end
        end)

        tgt.MouseEnter:Connect(function() Tween(tgt,{BackgroundColor3=Color3.fromRGB(60,20,100)}) end)
        tgt.MouseLeave:Connect(function() Tween(tgt,{BackgroundColor3=Color3.fromRGB(40,16,70)}) end)
        tgt.MouseButton1Click:Connect(function()
            -- single-fish auto-target: locks onto just this fish's rarity key
            local keys={[fish.rarityKey]=true}
            if isAutoRunning then AutoTarget:Stop() end
            SetAutoUI(true)
            AutoTarget:Start(keys, function(msg,col)
                atStatusLbl.Text=msg; atStatusLbl.TextColor3=col or T.TXT_DIM
                if col==T.CYAN then
                    Tween(atStatusFrame,{BackgroundColor3=Color3.fromRGB(10,40,60)})
                end
            end)
            -- switch to auto panel to show status
            AutoPanel.Visible=true
        end)

        card.MouseEnter:Connect(function() Tween(card,{BackgroundColor3=Color3.fromRGB(20,40,68)}) end)
        card.MouseLeave:Connect(function() Tween(card,{BackgroundColor3=T.BG_CARD}) end)
    end
end

scanPill.MouseButton1Click:Connect(function() BuildFishCards(true)  end)
allPill.MouseButton1Click:Connect(function()  BuildFishCards(false) end)

