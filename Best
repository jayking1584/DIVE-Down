sweepPill.MouseButton1Click:Connect(function()
    if zoneSweepRunning then return end
    scanPill.Active = false; allPill.Active = false; sweepPill.Active = false
    sweepPill.BackgroundColor3 = Color3.fromRGB(60,40,0)
    for _, c in ipairs(fishScroll:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end
    debugLbl.Text = ""
    SweepAllZones(nil,
        function(progress) statusLbl.Text = progress end,
        function(allFish, allRarity)
            statusLbl.Text = "Sweep done: " .. #allFish .. " fish across all zones"
            BuildCards(allFish, allRarity)
            scanPill.Active = true; allPill.Active = true; sweepPill.Active = true
            sweepPill.BackgroundColor3 = Color3.fromRGB(100,70,10)
        end
    )
end)

