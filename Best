AirTimer.onTick = function(remaining, total)
    local r     = math.max(0, remaining)
    local ratio = r / math.max(1, total)
    timerDisp.Text    = string.format("%d:%02d", math.floor(r/60), math.floor(r%60))
    timerBarFill.Size = UDim2.new(ratio, 0, 1, 0)
    if ratio > 0.5 then
        timerBarFill.BackgroundColor3 = T.CYAN; timerDisp.TextColor3 = T.TXT_WHITE
    elseif ratio > 0.25 then
        timerBarFill.BackgroundColor3 = T.ORANGE; timerDisp.TextColor3 = T.ORANGE
    else
        timerBarFill.BackgroundColor3 = T.RED; timerDisp.TextColor3 = T.RED
    end
end
AirTimer.onExpire = function()
    SetAirUI(false)
    timerDisp.Text = "0:00"; timerDisp.TextColor3 = T.RED
    timerSubLbl.Text = "SURFACING!"; timerSubLbl.TextColor3 = T.RED
    if remoteEvent then pcall(function() remoteEvent:FireServer("Aquarium") end) end
    task.delay(2, function()
        timerBarFill.Size = UDim2.new(1,0,1,0); timerBarFill.BackgroundColor3 = T.CYAN
        timerDisp.TextColor3 = T.TXT_WHITE
        timerDisp.Text = string.format("%d:%02d", airMins, airSecs)
        timerSubLbl.Text = "READY"; timerSubLbl.TextColor3 = T.GREEN
    end)
end
